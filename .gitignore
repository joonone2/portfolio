# Node.js dependencies
/node_modules

# Build outputs
/build
/dist

# Temporary files and logs
*.tmp
*.log
*.out

# Environment files
.env
.env.local
.env.*.local

# macOS system files
.DS_Store

# Linux file system
.Trash

# IDE settings (e.g., Visual Studio Code, IntelliJ)
.vscode/
.idea/

# npm & Yarn debug files
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore archive files
*.zip
*.tar.gz

# Ignore public keys (e.g., SSH keys)
*.pem
*.key

# Ignore config overrides (if you don't want to track these)
config-overrides.js

# Ignore coverage reports (if using testing frameworks)
coverage/
